<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

    <Package Name="Snapple"
             Version="0.1.0"
             Manufacturer="okwic"
             UpgradeCode="1A7CECBB-4203-40D7-B2E9-825AC94CB841"
             Compressed="yes"
             InstallerVersion="500"
             Scope="perMachine">

        <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
        <MediaTemplate EmbedCab="yes" />

        <StandardDirectory Id="ProgramFiles64Folder">
            <Directory Id="INSTALLFOLDER" Name="Snapple">
                <Component Id="SnappleExe" Guid="*">
                    <File Id="SnappleExe" Source="$(var.SnappleExePath)" KeyPath="yes" />
                </Component>
                <Component Id="FfmpegExe" Guid="*">
                    <File Id="FfmpegExe" Source="$(var.FfmpegExePath)" KeyPath="yes" />
                </Component>
            </Directory>
        </StandardDirectory>

        <StandardDirectory Id="ProgramMenuFolder">
            <Directory Id="SnappleMenuFolder" Name="Snapple">
                <Component Id="SnappleShortcut" Guid="*">
                    <Shortcut Id="SnappleStartMenuShortcut"
                              Name="Snapple"
                              Description="Game clip capture utility"
                              Target="[INSTALLFOLDER]Snapple.exe"
                              WorkingDirectory="INSTALLFOLDER" />
                    <RemoveFolder Id="RemoveSnappleMenuFolder" On="uninstall" />
                    <RegistryValue Root="HKCU" Key="Software\Snapple" Name="installed" Type="integer" Value="1" KeyPath="yes" />
                </Component>
            </Directory>
        </StandardDirectory>

        <Feature Id="Main" Title="Snapple" Level="1">
            <ComponentRef Id="SnappleExe" />
            <ComponentRef Id="FfmpegExe" />
            <ComponentRef Id="SnappleShortcut" />
        </Feature>

        <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    </Package>
</Wix>
